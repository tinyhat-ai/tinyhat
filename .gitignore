# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Python (scripts + scratch)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node (tooling, later)
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
dist/
build/

# Environment
.env
.env.local
.env.*.local

# --- Agent machine-local state ------------------------------------------
# Rule: ignore anything machine-specific (sessions, caches, chat history,
# hook state). Keep project-shared config (rules, skills, commands) so
# guidance travels with the repo. When onboarding a new agent, add its
# machine-local paths HERE before the agent's first commit.

# Claude Code — keep .claude/skills/, .claude/commands/, .claude/settings.json
.claude/backups/
.claude/cache/
.claude/downloads/
.claude/history.jsonl
.claude/plans/
.claude/projects/
.claude/session-env/
.claude/sessions/
.claude/shell-snapshots/
.claude/worktrees/

# Cursor — keep .cursor/rules/ (cross-agent skill adapters; see
# docs/cross-agent-skills.md). Ignore everything else machine-local.
.cursor/*
!.cursor/rules/

# Codex — AGENTS.md is the entry point; .codex is usually ~/.codex but
# ignore project-local variants defensively.
.codex/

# Codex skills — keep .agents/skills (symlink to .claude/skills for
# repo-local Codex discovery; see docs/cross-agent-skills.md). Ignore
# everything else under .agents/ defensively.
.agents/*
!.agents/skills

# Aider — keep .aider.conf.yml, .aiderignore if used
.aider*
!.aider.conf.yml
!.aiderignore

# Gemini CLI
.gemini/

# Continue.dev — keep committed config; ignore logs/sessions
.continue/logs/
.continue/sessions/
.continue/index/

# Windsurf / Cline / Roo — keep top-level .windsurfrules, .clinerules,
# .roomodes if the team commits them.
.windsurf/
.cline/
.roo/

# --- Local override files (internal-only; never commit) -----------------
# These can hold internal maintainer context and private references. See
# AGENTS.md#local-override-files. The `.example` counterparts ARE committed
# and must not name private resources.
CLAUDE.local.md
AGENTS.local.md
.agent-local/

# --- Tinyhat probe output (local machine snapshots — not shareable) -----
*.probe.out.txt
claude-config-probe.out.txt
claude-session-format-probe.out.txt

# --- Tinyhat local-dev test harnesses -----------------------------------
# These shadow the production skills/*/ for in-session testing without
# restarting Claude Code. Delete before merging any PR that depends on
# them. They use hardcoded paths and are maintainer-machine-specific.
.claude/skills/skill-audit/
.claude/skills/open-latest-audit/
.claude/skills/audit-history/

# --- CI scratch + generated artifacts -----------------------------------
.ruff_cache/
dist/
build/
*.egg-info/
