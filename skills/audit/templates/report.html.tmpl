<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Skill Audit · Tinyhat</title>
<style>
{{CSS}}
</style>
</head>
<body class="mode-main">
<div class="wrap">

  <header class="report-header">
    <div class="report-header-top">
      <div>
        <div class="kicker">Tinyhat · Skill Audit</div>
        <h1 class="report-title">Which skills are actually earning their keep?</h1>
        <p class="report-sub">A local, read-only look at how your Claude skills show up in the work you've actually been doing.</p>
        <p class="report-meta">Generated {{GENERATED_AT}} · window: {{WINDOW_LABEL}} · <a href="{{ARCHIVE_INDEX_HREF}}" class="report-meta-link">all reports →</a></p>
      </div>
      <div class="mode-switch" role="tablist" aria-label="Report detail mode">
        <button class="mode-btn" data-mode="main" type="button" onclick="setMode('main')"><span>✨</span><span>Keep it simple</span></button>
        <button class="mode-btn" data-mode="details" type="button" onclick="setMode('details')"><span>🤓</span><span>Data junkie mode</span></button>
      </div>
    </div>
  </header>

  <section class="pie-grid">
    <div class="pie-card">
      <div class="pie" style="--value: {{UTILIZATION_PCT}}%; --pie-color: var(--accent);">
        <div class="pie-center"><strong>{{UTILIZATION_PCT}}%</strong><span>active</span></div>
      </div>
      <div class="pie-copy">
        <h3>Skill utilization</h3>
        <p>{{ACTIVE_COUNT}} of {{INSTALLED_COUNT}} installed skills had at least one run.</p>
      </div>
    </div>
    <div class="pie-card">
      <div class="pie" style="--value: {{SESSION_SKILL_PCT}}%; --pie-color: var(--warm);">
        <div class="pie-center"><strong>{{SESSION_SKILL_PCT}}%</strong><span>sessions</span></div>
      </div>
      <div class="pie-copy">
        <h3>Sessions with skills</h3>
        <p>{{SESSIONS_WITH_SKILLS}} of {{SESSIONS_TOTAL}} recent sessions fired at least one skill.</p>
      </div>
    </div>
  </section>

  <section class="main-only next-actions">
    <div class="kicker">Pick a next step</div>
    <h2>What to do next</h2>
    <ol class="next-action-list">{{NEXT_ACTIONS_HTML}}</ol>
  </section>

  <section class="details-only hero">
    <h2 class="hero-headline">{{HEADLINE}}</h2>
    <p class="small">{{HEADLINE_SUB}}</p>

    <div class="stat-group">
      <div class="stat-group-label">Skills</div>
      <div class="stats">
        <div class="stat"><span class="n">{{INSTALLED_COUNT}}</span><span class="label">Installed</span></div>
        <div class="stat"><span class="n">{{ACTIVE_COUNT}}</span><span class="label">Active this window</span></div>
        <div class="stat"><span class="n">{{SKILL_RUNS_TOTAL}}</span><span class="label">Skill runs detected</span></div>
      </div>
    </div>

    <div class="stat-group">
      <div class="stat-group-label">Overall Claude Code usage</div>
      <div class="stats">
        <div class="stat"><span class="n">{{SESSIONS_TOTAL}}</span><span class="label">Sessions</span></div>
        <div class="stat"><span class="n">{{TURNS_TOTAL_COMPACT}}</span><span class="label">Turns</span></div>
        <div class="stat"><span class="n">{{TOKENS_TOTAL_COMPACT}}</span><span class="label">Token activity</span></div>
      </div>
    </div>
  </section>

  <section>
    <div class="kicker">Recommended skills</div>
    <h2>What to create next</h2>
    <div class="recommend-grid">{{RECOMMENDATION_CARDS}}</div>
  </section>

  <div class="main-only mode-cta">
    <div class="mode-cta-lead">
      <strong>🤓 Still reading? That's suspicious.</strong>
      <p class="small" style="margin: 4px 0 0;">You might be a data junkie. There's a lot more underneath — sessions, tool usage, activity patterns, the whole coverage story.</p>
    </div>
    <button class="action-btn" type="button" onclick="setMode('details')">Feed me the data →</button>
  </div>

  <!-- DETAILS-MODE-ONLY -->
  <section class="details-only back-bar">
    <button class="action-btn ghost" type="button" onclick="setMode('main')">← Back to overview</button>
    <span class="small">You're in data-junkie mode. Enjoy.</span>
  </section>

  <section class="agent-notes">
    <div class="kicker">Agent notes</div>
    <h2>What stands out in your last {{WINDOW_DAYS}} days</h2>
    <ul>{{STANDOUTS_HTML}}</ul>
  </section>

  <section class="details-only" id="dormant-section">
    <h2>Dormant skills</h2>
    <p class="small">{{DORMANT_COMMENTARY}}</p>
    <div class="dormant-grid">{{DORMANT_CARDS}}</div>
    <div class="cleanup-toolbar">
      <button class="action-btn ghost" type="button" onclick="cleanupSelectAll(true)">Select every dormant skill</button>
      <button class="action-btn ghost" type="button" onclick="cleanupSelectAll(false)">Clear all</button>
      <span class="small" id="cleanup-count" style="margin-left:auto;">0 selected</span>
      <button class="action-btn" type="button" id="cleanup-remove" disabled>Remove selected</button>
    </div>
    <p class="small">Coming soon — the real flow will confirm and then delete the selected skill directories.</p>
  </section>

  <section class="details-only">
    <h2>Top skills</h2>
    {{TOP_SKILL_CARDS}}
  </section>

  <section class="details-only">
    <h2>Session details</h2>
    <div class="filter-block">
      <div class="filter-row"><span class="filter-label">Sort</span><div class="chip-group" id="sort-chips">{{SORT_CHIPS}}</div></div>
      <div class="filter-row"><span class="filter-label">Surface</span><div class="chip-group" id="surface-chips">{{SURFACE_CHIPS}}</div></div>
      <div class="filter-row"><span class="filter-label">Project</span><div class="chip-group" id="project-chips">{{PROJECT_CHIPS}}</div></div>
    </div>
    <div id="session-list">{{SESSION_CARDS}}</div>
    <button class="action-btn ghost" type="button" id="show-all-sessions" onclick="showAllSessions()" style="margin-top:12px;">{{SHOW_ALL_SESSIONS_LABEL}}</button>
  </section>

  <section class="details-only">
    <h2>All tools used this period</h2>
    <p class="small" id="tools-summary">{{TOOLS_TOTAL}} calls across {{TOOLS_COUNT}} distinct tools.</p>
    <div class="filter-block">
      <div class="filter-row"><span class="filter-label">Surface</span><div class="chip-group" id="tools-surface-chips">{{TOOLS_SURFACE_CHIPS}}</div></div>
      <div class="filter-row"><span class="filter-label">Project</span><div class="chip-group" id="tools-project-chips">{{TOOLS_PROJECT_CHIPS}}</div></div>
    </div>
    <div id="tools-list"></div>
    <button class="action-btn ghost" type="button" id="show-all-tools" onclick="showAllTools()" style="margin-top:12px;">{{SHOW_ALL_TOOLS_LABEL}}</button>
  </section>

  <section class="details-only">
    <h2>Activity patterns</h2>
    <div class="chart-grid chart-grid-single">
      <div class="chart-card"><h3>Sessions per day</h3>{{CHART_SESSIONS}}</div>
      <div class="chart-card"><h3>Turns per day</h3>{{CHART_TURNS}}</div>
      <div class="chart-card"><h3>Token activity per day</h3>{{CHART_TOKENS}}</div>
      <div class="chart-card"><h3>Sessions by surface</h3>{{CHART_SURFACES}}</div>
    </div>
  </section>

  <section class="details-only coverage">
    <h2>Coverage</h2>
    <p>{{COVERAGE_NOTE}}</p>
    <ul>{{COVERAGE_ITEMS}}</ul>
  </section>

  <section class="details-only back-bar">
    <button class="action-btn ghost" type="button" onclick="setMode('main')">← Back to overview</button>
  </section>

  <!-- FEEDBACK - BOTH MODES -->
  <section class="feedback">
    <strong>Does this ranking feel right?</strong>
    <div class="feedback-row">
      <a class="action-btn ghost" href="mailto:tinyhat@tinyloop.co?subject={{FEEDBACK_SUBJECT}}%20%F0%9F%91%8D&body=The%20Tinyhat%20ranking%20felt%20right%20for%20me.%0A%0A(Optional)%20What%20was%20especially%20good%3A%0A">👍 Yes</a>
      <a class="action-btn ghost" href="mailto:tinyhat@tinyloop.co?subject={{FEEDBACK_SUBJECT}}%20%F0%9F%91%8E&body=The%20Tinyhat%20ranking%20felt%20off%20for%20me.%0A%0AWhat%20was%20wrong%3A%0A">👎 Something's off</a>
    </div>
    <textarea id="feedback-text" placeholder="(Optional) Anything specific? Goes into the email body." rows="2"></textarea>
    <div>
      <button class="action-btn" type="button" onclick="sendFeedbackEmail()" style="margin-top:10px;">Send feedback</button>
    </div>
    <p class="small" style="margin-top: 10px;">Feedback opens your email app pre-filled to <code>tinyhat@tinyloop.co</code>. No network call from this page.</p>
  </section>

</div>

<script>
  window.TINYHAT_TOOLS_PAYLOAD = {{TOOLS_PAYLOAD_JSON}};
  window.TINYHAT_FEEDBACK_SUBJECT = "{{FEEDBACK_SUBJECT}}";

  function setMode(mode) {
    document.body.classList.remove('mode-main', 'mode-details');
    document.body.classList.add('mode-' + mode);
  }

  function cleanupSelectAll(state) {
    document.querySelectorAll('.cleanup-check').forEach(cb => cb.checked = state);
    updateCleanupCount();
  }
  function updateCleanupCount() {
    const n = document.querySelectorAll('.cleanup-check:checked').length;
    const label = document.getElementById('cleanup-count');
    if (label) label.textContent = n + ' selected';
    const btn = document.getElementById('cleanup-remove');
    if (btn) btn.disabled = (n === 0);
  }
  document.addEventListener('change', (e) => {
    if (e.target && e.target.classList && e.target.classList.contains('cleanup-check')) updateCleanupCount();
  });

  // Sessions
  const SESSION_SHOW_INITIAL = 10;
  let sessionState = { sort: 'skill-desc', surface: 'all', project: 'all', showAll: false };
  function applySessionFilters() {
    const items = Array.from(document.querySelectorAll('.session-item'));
    const filtered = items.filter(el => {
      if (sessionState.surface !== 'all' && el.dataset.surface !== sessionState.surface) return false;
      if (sessionState.project !== 'all' && el.dataset.project !== sessionState.project) return false;
      return true;
    });
    filtered.sort((a, b) => {
      if (sessionState.sort === 'recent') return b.dataset.lastTs.localeCompare(a.dataset.lastTs);
      const rd = parseInt(b.dataset.skillRuns) - parseInt(a.dataset.skillRuns);
      return rd !== 0 ? rd : b.dataset.lastTs.localeCompare(a.dataset.lastTs);
    });
    const list = document.getElementById('session-list');
    items.forEach(el => el.style.display = 'none');
    const visible = sessionState.showAll ? filtered : filtered.slice(0, SESSION_SHOW_INITIAL);
    visible.forEach(el => { el.style.display = ''; list.appendChild(el); });
    const toggle = document.getElementById('show-all-sessions');
    if (toggle) toggle.style.display = (filtered.length <= SESSION_SHOW_INITIAL) ? 'none' : '';
  }
  function showAllSessions() {
    sessionState.showAll = !sessionState.showAll;
    applySessionFilters();
    const btn = document.getElementById('show-all-sessions');
    if (btn) btn.textContent = sessionState.showAll ? 'Show fewer' : '{{SHOW_ALL_SESSIONS_LABEL}}';
  }
  function bindSessionChips(groupId, key, attr) {
    const group = document.getElementById(groupId);
    if (!group) return;
    group.addEventListener('click', (e) => {
      const btn = e.target.closest('.chip-btn'); if (!btn) return;
      group.querySelectorAll('.chip-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      sessionState[key] = btn.dataset[attr];
      applySessionFilters();
    });
  }
  bindSessionChips('sort-chips', 'sort', 'sort');
  bindSessionChips('surface-chips', 'surface', 'surface');
  bindSessionChips('project-chips', 'project', 'project');
  applySessionFilters();

  // Tools
  const TOOLS_SHOW_INITIAL = 20;
  let toolsState = { surface: 'all', project: 'all', showAll: false };
  function renderTools() {
    const payload = window.TINYHAT_TOOLS_PAYLOAD || [];
    const totals = new Map();
    const reach = new Map();
    let totalCalls = 0;
    for (const row of payload) {
      if (toolsState.surface !== 'all' && row.surface !== toolsState.surface) continue;
      if (toolsState.project !== 'all' && row.project !== toolsState.project) continue;
      for (const [tool, n] of Object.entries(row.tools || {})) {
        totals.set(tool, (totals.get(tool) || 0) + n);
        if (!reach.has(tool)) reach.set(tool, new Set());
        reach.get(tool).add(row.session_id);
        totalCalls += n;
      }
    }
    const ranked = Array.from(totals.entries()).sort((a, b) => b[1] - a[1]);
    const max = ranked[0] ? ranked[0][1] : 1;
    const visible = toolsState.showAll ? ranked : ranked.slice(0, TOOLS_SHOW_INITIAL);
    const list = document.getElementById('tools-list');
    if (!list) return;
    list.innerHTML = visible.map(([tool, calls], idx) => {
      const r = reach.get(tool).size;
      const pct = Math.max(2, Math.floor(100 * calls / max));
      return `<div class="tools-row">
        <span class="tools-rank">${idx + 1}</span>
        <span class="tools-name"><code>${esc(tool)}</code></span>
        <div class="tools-bar"><span style="width:${pct}%"></span></div>
        <span class="tools-meta">${calls} calls · ${r} session${r === 1 ? '' : 's'}</span>
      </div>`;
    }).join('') || '<p class="small">No tool activity matches the current filters.</p>';
    const summary = document.getElementById('tools-summary');
    if (summary) summary.textContent = `${totalCalls} calls across ${ranked.length} distinct tools.`;
    const toggle = document.getElementById('show-all-tools');
    if (toggle) toggle.style.display = (ranked.length <= TOOLS_SHOW_INITIAL) ? 'none' : '';
  }
  function showAllTools() {
    toolsState.showAll = !toolsState.showAll;
    renderTools();
    const btn = document.getElementById('show-all-tools');
    if (btn) btn.textContent = toolsState.showAll ? 'Show fewer' : '{{SHOW_ALL_TOOLS_LABEL}}';
  }
  function esc(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
  function bindToolsChips(groupId, key, attr) {
    const group = document.getElementById(groupId);
    if (!group) return;
    group.addEventListener('click', (e) => {
      const btn = e.target.closest('.chip-btn'); if (!btn) return;
      group.querySelectorAll('.chip-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      toolsState[key] = btn.dataset[attr];
      renderTools();
    });
  }
  bindToolsChips('tools-surface-chips', 'surface', 'surface');
  bindToolsChips('tools-project-chips', 'project', 'project');
  renderTools();

  function sendFeedbackEmail() {
    const text = document.getElementById('feedback-text').value || '';
    const body = encodeURIComponent(text ? `${text}\n\n— Sent from the Tinyhat report.` : 'Sent from the Tinyhat report.');
    const subject = (window.TINYHAT_FEEDBACK_SUBJECT || 'Tinyhat%20feedback');
    window.location.href = `mailto:tinyhat@tinyloop.co?subject=${subject}&body=${body}`;
  }
</script>
</body>
</html>
